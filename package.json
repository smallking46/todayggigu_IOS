{
  "name": "my-package",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "build": "babel src -d lib",
    "test": "jest",
    "metro:free8081": "node ./scripts/free-metro-8081.cjs",
    "start": "react-native start --host 0.0.0.0",
    "start:clean": "node ./scripts/free-metro-8081.cjs && react-native start --host 0.0.0.0",
    "start:8082": "react-native start --host 0.0.0.0 --port 8082",
    "start:reset": "react-native start --host 0.0.0.0 --reset-cache",
    "start:reset:clean": "node ./scripts/free-metro-8081.cjs && react-native start --host 0.0.0.0 --reset-cache",
    "dev:android": "concurrently -k -n metro,android -c blue,green \"react-native start --host 0.0.0.0\" \"wait-on tcp:8081 && adb reverse tcp:8081 tcp:8081 && react-native run-android --no-packager\"",
    "dev:ios": "concurrently -k -n metro,ios -c blue,green \"react-native start --host 0.0.0.0\" \"wait-on tcp:8081 && react-native run-ios --no-packager\"",
    "android": "adb reverse tcp:8081 tcp:8081 && react-native run-android",
    "android:no-packager": "adb reverse tcp:8081 tcp:8081 && react-native run-android --no-packager",
    "android:clean": "cd android && ./gradlew clean && cd .. && adb reverse tcp:8081 tcp:8081 && react-native run-android",
    "ios": "react-native run-ios",
    "ios:no-packager": "react-native run-ios --no-packager",
    "rn:hint": "node ./scripts/rn-connection.cjs",
    "rn:devices": "adb devices",
    "adb:reverse": "adb reverse tcp:8081 tcp:8081"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.6",
    "@invertase/react-native-apple-authentication": "^2.5.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-camera-roll/camera-roll": "^7.10.2",
    "@react-native-clipboard/clipboard": "^1.14.1",
    "@react-native-community/cli": "latest",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-google-signin/google-signin": "^16.0.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^2.2.6",
    "axios": "^1.12.2",
    "js-sha256": "^0.11.1",
    "lodash": "^4.17.21",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-config": "^1.6.1",
    "react-native-confirmation-code-field": "^8.0.1",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-crop-picker": "^0.51.0",
    "react-native-image-picker": "^7.1.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-svg-transformer": "^1.5.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-vision-camera": "^4.7.3",
    "react-native-webview": "^13.16.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@react-native/metro-config": "^0.81.4",
    "@types/lodash": "^4.14.202",
    "@types/react": "~19.1.10",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "concurrently": "^9.1.2",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.1"
  },
  "private": true
}
